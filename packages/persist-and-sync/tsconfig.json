{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"rootDir": "./src",
		"declaration": true,
		"esModuleInterop": true,
		"moduleResolution": "nodenext",
		"skipLibCheck": true,
		"module": "nodenext",
		"strict": true,
		"outDir": "dist"
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
